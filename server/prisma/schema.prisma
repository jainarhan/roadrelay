// schema.prisma

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  FLEET_MANAGER
  DRIVER
  SAFETY_OFFICER
  FINANCIAL_ANALYST
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
  SUSPENDED
}

enum TripStatus {
  DRAFT
  DISPATCHED
  COMPLETED
  CANCELLED
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         Role
  createdAt    DateTime @default(now())
  driverId     String?  @unique
  driver       Driver?  @relation(fields: [driverId], references: [id])
}

model Vehicle {
  id               String        @id @default(uuid())
  regNumber        String        @unique
  name             String
  type             String
  maxLoadCapacity  Float
  odometer         Float         @default(0)
  acquisitionCost  Float
  status           VehicleStatus @default(AVAILABLE)
  createdAt        DateTime      @default(now())

  trips            Trip[]
  maintenanceLogs  MaintenanceLog[]
  fuelLogs         FuelLog[]
  expenses         Expense[]

  @@index([status])
}

model Driver {
  id              String       @id @default(uuid())
  name            String
  licenseNumber   String       @unique
  licenseCategory String
  licenseExpiry   DateTime
  contact         String
  safetyScore     Float        @default(100)
  status          DriverStatus @default(AVAILABLE)
  createdAt       DateTime     @default(now())

  trips           Trip[]
  user            User?

  @@index([status])
}

model Trip {
  id              String     @id @default(uuid())
  source          String
  destination     String
  vehicleId       String
  driverId        String
  cargoWeight     Float
  plannedDistance Float
  odometerEnd     Float?
  revenue         Float?     // needed for ROI report — capture at trip creation/completion
  status          TripStatus @default(DRAFT)
  dispatchedAt    DateTime?
  completedAt     DateTime?
  createdAt       DateTime   @default(now())

  vehicle         Vehicle    @relation(fields: [vehicleId], references: [id])
  driver          Driver     @relation(fields: [driverId], references: [id])
  fuelLogs        FuelLog[]

  @@index([status])
  @@index([vehicleId])
  @@index([driverId])
}

model MaintenanceLog {
  id          String   @id @default(uuid())
  vehicleId   String
  description String
  cost        Float    @default(0)
  active      Boolean  @default(true)
  openedAt    DateTime @default(now())
  closedAt    DateTime?

  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId, active])
}

model FuelLog {
  id        String   @id @default(uuid())
  vehicleId String
  tripId    String?
  liters    Float
  cost      Float
  date      DateTime @default(now())

  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])
  trip      Trip?    @relation(fields: [tripId], references: [id])

  @@index([vehicleId])
}

model Expense {
  id        String   @id @default(uuid())
  vehicleId String
  type      String   // e.g. TOLL, INSURANCE, PERMIT, MISC
  amount    Float
  date      DateTime @default(now())

  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId])
}
